# Copy these names into Vercel → Project → Settings → Environment Variables.
# NEVER commit real keys. NEVER put keys in the frontend/public folder.

ANTHROPIC_API_KEY=your_new_anthropic_key_here
SARVAM_API_KEY=your_new_sarvam_key_here

